{
  "name": "rockorbust-monorepo",
  "private": true,
  "workspaces": [
    "apps/gateway",
    "apps/web",
    "packages/playwright-plugin",
    "packages/extra-plugin"
  ],
  "scripts": {
    "gateway:dev": "npm run dev -w gateway",
    "gateway:build": "npm run build -w gateway",
    "plugin:build": "npm run build -w @rockorbust/playwright-plugin",
    "plugin:dev": "npm run dev -w @rockorbust/playwright-plugin",
    "cli:build": "cd apps/cli && go build -o ../../bin/rockorbust main.go",
    "build:all": "npm run gateway:build && npm run plugin:build && npm run cli:build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pratikpatwe/RockOrBust.git"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
